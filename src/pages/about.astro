---
import Header from '../components/Header.astro'
import Footer from '../components/ui/Footer.astro'
import { footerConfig } from '../data/footer'

const YOUTUBE_URL = 'https://www.youtube.com/@Easy_Yield';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/api/images/site/easyyield-logo.png" />
  <!-- Preload and static Tailwind CSS (built at build-time) -->
  <link rel="preload" href="/tailwind.css?v=20260628e" as="style">
  <link rel="stylesheet" href="/tailwind.css?v=20260628e">
  <!-- Minimal critical CSS to avoid FOUC until tailwind.css loads -->
  <style>
    html,body{font-family:Inter,system-ui,-apple-system}
  </style>
  <script> window.FontAwesomeConfig = { autoReplaceSvg: 'nest'};</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&amp;display=swap" />
  <title>About Easy Yield</title>
  <meta name="description" content="Meet Easy Yield — a Canadian personal-finance comics and vlog series starring Mike, who makes TFSAs, RRSPs, FHSAs, saving, investing, and budgeting easy and fun." />
  <link rel="canonical" href="https://easyyield.ca/about" />
  <link rel="stylesheet" href="/styles/brand.css?v=20260629b">
</head>
<body class="bg-[#101827]">
  <Header />

  <main class="pt-24 pb-16">
    <div class="container mx-auto px-6">

      <!-- Main Content -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16 items-center">
        <div class="space-y-6">
          <h1 class="text-4xl font-bold text-white">About Easy Yield</h1>
          <div class="space-y-4 text-slate-300 leading-relaxed">
            <p>
              Easy Yield is a comics and vlog series with one simple mission: make Canadian personal finance easy and actually fun. Money topics can feel intimidating and dry — so we tell them as stories instead, with a friendly cast and a lot of heart.
            </p>
            <p>
              At the center of it all is <strong>Mike</strong> — our everyday Canadian who is figuring out his money just like the rest of us. Through Mike's adventures we tackle the stuff that really matters here at home: TFSAs, RRSPs, FHSAs, RESPs, high-interest savings, GICs, dividend and index investing, budgeting, credit, Canadian taxes, mortgages and rates, and tips for first-time home buyers.
            </p>
            <p>
              New comics and videos land on our <a href={YOUTUBE_URL} target="_blank" rel="noopener noreferrer" class="text-[var(--brand-600,#0f766e)] hover:text-[var(--brand-700,#115e59)] font-semibold">YouTube channel</a>, and the blog goes deeper on each topic — clear, jargon-free, and made for real Canadian life.
            </p>
          </div>
          <div class="pt-2">
            <a href={YOUTUBE_URL} target="_blank" rel="noopener noreferrer" class="btn-cta inline-flex items-center gap-2">
              <i class="fab fa-youtube text-xl"></i> Watch Easy Yield on YouTube
            </a>
          </div>
        </div>

        <div class="flex justify-center">
          <img src="/api/images/site/Mike.png?v=20260627" alt="Mike waving hello" class="w-full max-w-[12rem] object-contain drop-shadow-2xl" />
        </div>
      </div>

      <!-- What to Expect -->
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-white mb-12">What You'll Find Here</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 mx-auto mb-4">
              <img src="/api/images/site/canadian.png?v=20260627" alt="" class="w-full h-full object-contain" />
            </div>
            <h3 class="text-xl font-bold text-neutral-900 mb-3">Made for Canada</h3>
            <p class="text-neutral-600">TFSAs, RRSPs, FHSAs and more — real accounts, real rules, explained for where you actually live.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 mx-auto mb-4">
              <img src="/api/images/site/vlogs.png?v=20260627" alt="" class="w-full h-full object-contain" />
            </div>
            <h3 class="text-xl font-bold text-neutral-900 mb-3">Comics &amp; Vlogs</h3>
            <p class="text-neutral-600">Mike turns dry money lessons into short, friendly stories you'll actually want to finish.</p>
          </div>
          <div class="bg-white rounded-2xl p-8 shadow-lg">
            <div class="w-16 h-16 mx-auto mb-4">
              <img src="/api/images/site/grow.png?v=20260627" alt="" class="w-full h-full object-contain" />
            </div>
            <h3 class="text-xl font-bold text-neutral-900 mb-3">Easy to Start</h3>
            <p class="text-neutral-600">No jargon, no judgment — just clear next steps to help your money grow, a little at a time.</p>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer
    companyName={footerConfig.companyName}
    showSocialLinks={footerConfig.showSocialLinks}
    showQuickLinks={footerConfig.showQuickLinks}
    showNewsletter={footerConfig.showNewsletter}
  />
</body>
</html>

---
import Header from '../components/Header.astro'
import Footer from '../components/ui/Footer.astro'
import { footerConfig } from '../data/footer'
import { getChannelVideos } from '../lib/youtube-videos'

const env = (Astro.locals as any)?.env;
const CHANNEL_ID = 'UCJ6fa6JxMw3hA15TVvC2EWg';
const YOUTUBE_URL = 'https://www.youtube.com/@Easy_Yield';

const videos = await getChannelVideos(env?.DB, CHANNEL_ID);
const PER_PAGE = 6;
const totalPages = Math.max(1, Math.ceil(videos.length / PER_PAGE));
const reqPage = parseInt(new URL(Astro.request.url).searchParams.get('page') || '1', 10) || 1;
const cur = Math.min(Math.max(1, reqPage), totalPages);
const pageVideos = videos.slice((cur - 1) * PER_PAGE, cur * PER_PAGE);

// Browser/edge cache the (public) video list; D1 holds the source-of-truth cache.
Astro.response.headers.set('Cache-Control', 'public, max-age=600, stale-while-revalidate=3600');
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/easyyield-logo.png" />
  <title>Easy Yield — Canadian Personal Finance, Made Easy &amp; Fun</title>
  <meta name="description" content="Easy Yield is a comics &amp; vlog series that makes Canadian personal finance easy and fun. Follow Mike as he tackles TFSAs, RRSPs, FHSAs, saving, investing, budgeting and more — one video at a time." />
  <link rel="canonical" href="https://easyyield.ca/" />
  <link rel="preload" href="/tailwind.css?v=20260628e" as="style">
  <link rel="stylesheet" href="/tailwind.css?v=20260628e">
  <style>
    html,body{font-family:'Inter',system-ui,-apple-system}
  </style>
  <script> window.FontAwesomeConfig = { autoReplaceSvg: 'nest'};</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Inter:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/brand.css?v=20260628d">
  <script is:inline src="/js/analytics.js" defer></script>
</head>

<div>
  <Header />

  <main id="main" class="pt-28 pb-20 min-h-[60vh]" style="background-color:#101827">
    <div class="container mx-auto px-6">
      {videos.length === 0 ? (
        <p class="text-center text-gray-300 py-16">
          New videos coming soon — <a class="underline font-medium" href={YOUTUBE_URL} target="_blank" rel="noopener">subscribe on YouTube</a>.
        </p>
      ) : (
        <Fragment>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {pageVideos.map((v) => (
              <a href={`https://www.youtube.com/watch?v=${v.id}`} target="_blank" rel="noopener"
                 class="group block rounded-2xl overflow-hidden bg-[#1E293B] shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <div class="relative aspect-video bg-black">
                  <img src={v.thumb} alt={v.title} loading="lazy" class="w-full h-full object-cover" />
                  <span class="absolute inset-0 flex items-center justify-center">
                    <span class="w-16 h-16 rounded-full bg-black/55 group-hover:bg-red-600 transition-colors flex items-center justify-center">
                      <i class="fas fa-play text-white text-2xl ml-1"></i>
                    </span>
                  </span>
                </div>
                <div class="p-5">
                  <h2 class="text-lg md:text-xl font-semibold leading-snug text-slate-50">{v.title}</h2>
                  <p class="text-sm text-slate-400 mt-2">{v.published ? new Date(v.published).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' }) : ''}</p>
                </div>
              </a>
            ))}
          </div>

          {totalPages > 1 && (
            <nav class="flex flex-wrap justify-center items-center gap-2 mt-12" aria-label="Video pages">
              {cur > 1 && <a rel="prev" href={`/?page=${cur - 1}`} class="px-4 py-2 rounded-lg border border-white/25 text-white hover:bg-white/10 font-medium">Prev</a>}
              {Array.from({ length: totalPages }, (_, i) => i + 1).map((n) => (
                <a href={`/?page=${n}`} aria-current={n === cur ? 'page' : undefined} class={`px-4 py-2 rounded-lg font-medium ${n === cur ? 'bg-white text-black' : 'border border-white/25 text-white hover:bg-white/10'}`}>{n}</a>
              ))}
              {cur < totalPages && <a rel="next" href={`/?page=${cur + 1}`} class="px-4 py-2 rounded-lg border border-white/25 text-white hover:bg-white/10 font-medium">Next</a>}
            </nav>
          )}
        </Fragment>
      )}
    </div>
  </main>

  <Footer
    companyName={footerConfig.companyName}
    showSocialLinks={footerConfig.showSocialLinks}
    showQuickLinks={footerConfig.showQuickLinks}
    showNewsletter={footerConfig.showNewsletter}
  />
</div>

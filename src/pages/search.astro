---
import Layout from '../layouts/Layout.astro';

const title = "Search Results | Easy Yield";
const description = "Search Easy Yield blog posts on Canadian personal finance.";

// Get search query from URL
const query = Astro.url.searchParams.get('q') || '';
---

<Layout title={title} description={description}>
  <main class="min-h-screen pt-24 pb-12">
    <div class="container mx-auto px-6">
      <div>

        <!-- Search Header -->
        <div class="text-center mb-12">
          <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
            {query ? `Search Results for "${query}"` : 'Search Blog Posts'}
          </h1>

          <!-- Search Input -->
          <div class="relative max-w-2xl mx-auto">
            <input
              id="main-search-input"
              type="text"
              value={query}
              placeholder="Search blog posts..."
              class="w-full px-6 py-4 pl-14 pr-14 bg-white border-2 border-neutral-200 rounded-2xl focus:ring-2 focus:ring-[var(--brand-500,#10b981)] focus:border-[var(--brand-500,#10b981)] transition-all text-lg shadow-lg"
              autocomplete="off"
            >
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
              <i class="fa-solid fa-search text-neutral-400 text-xl"></i>
            </div>
            <button id="main-search-clear" class="absolute inset-y-0 right-0 pr-5 flex items-center text-neutral-400 hover:text-neutral-600 transition-colors">
              <i class="fa-solid fa-times text-xl"></i>
            </button>
          </div>
        </div>

        <!-- Loading State -->
        <div id="search-loading" class="hidden text-center py-16">
          <div class="animate-spin rounded-full h-16 w-16 border-b-2 border-[var(--brand-600,#0f766e)] mx-auto"></div>
          <p class="text-neutral-600 text-lg mt-4">Searching...</p>
        </div>

        <!-- No Query State -->
        <div id="no-query-state" class={`text-center py-16 ${query ? 'hidden' : ''}`}>
          <i class="fa-solid fa-search text-neutral-300 text-6xl mb-6"></i>
          <h2 class="text-2xl font-bold text-neutral-700 mb-4">Start Your Search</h2>
          <p class="text-neutral-600 max-w-lg mx-auto">
            Enter keywords above to search our blog posts on Canadian personal finance.
          </p>
          <div class="flex flex-wrap justify-center gap-3 mt-8">
            <a href="/blog" class="px-4 py-2 bg-purple-100 text-purple-700 rounded-full hover:bg-purple-200 transition-colors text-sm">
              Read Our Blog
            </a>
          </div>
        </div>

        <!-- Search Results -->
        <div id="search-results-container" class={query ? '' : 'hidden'}>
          <!-- Results Info -->
          <div id="results-info" class="hidden mb-8 text-center">
            <p class="text-neutral-600">
              Found <span id="results-count" class="font-semibold text-[var(--brand-600,#0f766e)]"></span> results
            </p>
          </div>

          <!-- Results Grid -->
          <div id="results-grid" class="grid gap-6">
            <!-- Results will be populated here -->
          </div>

          <!-- Tag matrix -->
          <div id="tag-matrix" class="hidden mt-12 pt-8 border-t border-neutral-200">
            <h3 class="text-sm font-semibold text-neutral-400 uppercase tracking-wide mb-4">Browse by Topic</h3>
            <div id="tag-matrix-pills" class="flex flex-wrap gap-2"></div>
          </div>

          <!-- Empty Results -->
          <div id="empty-results" class="hidden text-center py-16">
            <i class="fa-solid fa-search text-neutral-300 text-6xl mb-6"></i>
            <h2 class="text-2xl font-bold text-neutral-700 mb-4">No Results Found</h2>
            <p class="text-neutral-600 max-w-lg mx-auto mb-8">
              We couldn't find any blog posts matching your search. Try different keywords.
            </p>
            <div class="flex flex-wrap justify-center gap-3">
              <a href="/blog" class="px-4 py-2 bg-purple-100 text-purple-700 rounded-full hover:bg-purple-200 transition-colors text-sm">
                Read Our Blog
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </main>
</Layout>

<script>
  let searchTimeout;
  const searchInput = document.getElementById('main-search-input');
  const clearBtn = document.getElementById('main-search-clear');
  const loadingEl = document.getElementById('search-loading');
  const noQueryState = document.getElementById('no-query-state');
  const resultsContainer = document.getElementById('search-results-container');
  const resultsInfo = document.getElementById('results-info');
  const resultsGrid = document.getElementById('results-grid');
  const emptyResults = document.getElementById('empty-results');
  const resultsCount = document.getElementById('results-count');

  // Get initial query from URL
  const urlParams = new URLSearchParams(window.location.search);
  let currentQuery = urlParams.get('q') || '';
  const tagParam   = urlParams.get('tag') || '';

  // If ?tag= was passed, redirect to blog with that tag
  if (tagParam && !currentQuery) {
    window.location.replace(`/blog?tag=${encodeURIComponent(tagParam)}`);
  }

  // Load tag matrix once
  loadTagMatrix();

  // Initialize
  if (currentQuery) {
    searchInput.value = currentQuery;
    performSearch(currentQuery);
  }

  // Search input handling
  searchInput.addEventListener('input', (e) => {
    const query = e.target.value.trim();

    const url = new URL(window.location);
    if (query) {
      url.searchParams.set('q', query);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url);

    clearBtn.style.display = query.length > 0 ? 'flex' : 'none';

    if (query.length === 0) {
      showNoQueryState();
      return;
    }

    clearTimeout(searchTimeout);
    if (query.length >= 2) {
      searchTimeout = setTimeout(() => performSearch(query), 300);
    }
  });

  // Clear button
  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    clearBtn.style.display = 'none';

    const url = new URL(window.location);
    url.searchParams.delete('q');
    window.history.replaceState({}, '', url);

    showNoQueryState();
  });

  // Handle Enter key
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      const query = searchInput.value.trim();
      if (query.length >= 2) {
        clearTimeout(searchTimeout);
        performSearch(query);
      }
    }
  });

  async function performSearch(query) {
    currentQuery = query;
    showLoading();

    try {
      const response = await fetch(`/api/search?q=${encodeURIComponent(query)}&limit=20`);
      const data = await response.json();

      if (data.results && data.results.length > 0) {
        displayResults(data.results);
      } else {
        showEmptyResults();
      }
    } catch (error) {
      console.error('Search error:', error);
      showEmptyResults();
    }
  }

  function showLoading() {
    loadingEl.classList.remove('hidden');
    noQueryState.classList.add('hidden');
    resultsContainer.classList.add('hidden');
  }

  function showNoQueryState() {
    loadingEl.classList.add('hidden');
    noQueryState.classList.remove('hidden');
    resultsContainer.classList.add('hidden');
  }

  function showEmptyResults() {
    loadingEl.classList.add('hidden');
    noQueryState.classList.add('hidden');
    resultsContainer.classList.remove('hidden');
    resultsInfo.classList.add('hidden');
    resultsGrid.innerHTML = '';
    emptyResults.classList.remove('hidden');
  }

  function displayResults(results) {
    loadingEl.classList.add('hidden');
    noQueryState.classList.add('hidden');
    resultsContainer.classList.remove('hidden');
    emptyResults.classList.add('hidden');

    resultsCount.textContent = results.length;
    resultsInfo.classList.remove('hidden');

    const blogPosts = results.filter(r => r.type === 'blog');

    let html = '';

    if (blogPosts.length > 0) {
      html += `
        <div>
          <h2 class="text-2xl font-bold text-neutral-900 mb-6 flex items-center">
            <i class="fa-solid fa-blog text-purple-600 mr-3"></i>
            Blog Posts (${blogPosts.length})
          </h2>
          <div class="space-y-6">
            ${blogPosts.map(post => `
              <a href="${post.url}" class="bg-white rounded-2xl shadow-sm border border-neutral-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 overflow-hidden group flex">
                ${post.image ?
                  `<div class="w-48 h-32 flex-shrink-0 overflow-hidden bg-neutral-100">
                    <img src="${post.image}" alt="${post.title}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                  </div>` :
                  `<div class="w-48 h-32 flex-shrink-0 bg-gradient-to-br from-purple-50 to-indigo-50 flex items-center justify-center">
                    <i class="fa-solid fa-blog text-3xl text-purple-300"></i>
                  </div>`
                }
                <div class="p-6 flex-1">
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="font-bold text-neutral-900 group-hover:text-purple-700 line-clamp-2">${post.title}</h3>
                    ${post.category ? `<span class="text-xs text-purple-600 bg-purple-50 px-2 py-1 rounded-full whitespace-nowrap ml-2">${post.category}</span>` : ''}
                  </div>
                  ${post.excerpt ? `<p class="text-sm text-neutral-600 mb-3 line-clamp-2">${post.excerpt}</p>` : ''}
                  ${post.published_at ? `<p class="text-xs text-neutral-500">Published ${new Date(post.published_at).toLocaleDateString()}</p>` : ''}
                </div>
              </a>
            `).join('')}
          </div>
        </div>
      `;
    }

    resultsGrid.innerHTML = html;
  }

  async function loadTagMatrix() {
    try {
      const blogRes = await fetch('/api/blog/posts');
      const blogData = await blogRes.json();

      const tagSet = new Set();
      (blogData.data || []).forEach(p => {
        if (p.tags) p.tags.split(',').map(t => t.trim()).filter(Boolean).forEach(t => tagSet.add(t));
      });

      const tags = Array.from(tagSet).sort();
      if (!tags.length) return;

      const pillsEl = document.getElementById('tag-matrix-pills');
      pillsEl.innerHTML = tags.map(tag => {
        const disp = tag.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
        return `<a href="/blog?tag=${encodeURIComponent(tag)}"
          class="px-3 py-1 text-xs font-medium rounded-full bg-neutral-100 text-neutral-600 hover:bg-[var(--brand-50,#ecfdf5)] hover:text-[var(--brand-700,#115e59)] transition-colors">${disp}</a>`;
      }).join('');

      document.getElementById('tag-matrix').classList.remove('hidden');
    } catch {}
  }

  // Add Tailwind line clamp utilities
  const style = document.createElement('style');
  style.textContent = `
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  `;
  document.head.appendChild(style);
</script>

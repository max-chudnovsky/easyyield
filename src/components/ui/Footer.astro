---
import type { FooterProps } from '../../types/components';

const {
  companyName = "Easy Yield",
  currentYear = new Date().getFullYear(),
  showSocialLinks = true,
  showQuickLinks = true,
  showNewsletter = true
} = Astro.props as FooterProps;
---

<footer class="bg-neutral-900 text-white">
  <div class="container mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <!-- Company Info -->
      <div class="space-y-4">
        <div class="flex items-center space-x-2">
          <img src="/images/easyyield-logo.png" alt={`${companyName} Logo`} class="h-8 w-auto">
          <span class="text-2xl font-bold footer-brand">{companyName}</span>
        </div>
        <p class="text-neutral-400 leading-relaxed">
          Canadian personal finance made easy and fun. Easy Yield is a comics &amp; vlog series where <em>Mike</em> breaks down TFSAs, RRSPs, FHSAs, saving, investing, budgeting and taxes — one friendly comic at a time.
        </p>
        {showSocialLinks && (
          <div class="flex space-x-4">
            <a href="https://www.youtube.com/channel/UCJ6fa6JxMw3hA15TVvC2EWg" target="_blank" rel="noopener noreferrer" class="text-neutral-400 hover:text-white transition-colors duration-200" aria-label="YouTube">
              <i class="fab fa-youtube text-xl"></i>
            </a>
          </div>
        )}
      </div>

      {showQuickLinks && (
        <>
          <!-- Quick Links -->
          <div class="space-y-4">
            <h3 class="text-lg font-semibold">Quick Links</h3>
            <ul class="grid grid-cols-2 gap-x-4 gap-y-2">
              <li><a href="/" class="text-neutral-400 hover:text-white transition-colors duration-200">Home</a></li>
              <li><a href="/blog" class="text-neutral-400 hover:text-white transition-colors duration-200">Blog</a></li>
              <li><a href="/about" class="text-neutral-400 hover:text-white transition-colors duration-200">About</a></li>
              <li><a href="/contact" class="text-neutral-400 hover:text-white transition-colors duration-200">Contact</a></li>
              <li><a href="/privacy" class="text-neutral-400 hover:text-white transition-colors duration-200">Privacy</a></li>
            </ul>
          </div>
        </>
      )}

      {showNewsletter && (
        <!-- Newsletter -->
        <div class="space-y-4">
          <h3 class="text-lg font-semibold">Stay Updated</h3>
          <p class="text-neutral-400 text-sm">Subscribe for new comics, money tips, and Canadian personal-finance updates from Easy Yield.</p>
          <form id="newsletter-form" class="space-y-3">
            <div class="relative">
              <input
                id="newsletter-email"
                type="email"
                placeholder="Enter your email"
                class="w-full px-4 py-3 bg-neutral-800 border border-neutral-700 rounded-lg focus:ring-2 focus:ring-[var(--brand-500,#10b981)] focus:border-[var(--brand-500,#10b981)] transition-all text-white placeholder-neutral-400"
                required
              >
            </div>
            <button
              type="submit"
              id="newsletter-submit"
              class="btn-cta w-full"
            >
              <span id="newsletter-text">Subscribe</span>
            </button>
            <div id="newsletter-message" class="text-sm hidden"></div>
          </form>
        </div>
      )}
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-neutral-800">
    <div class="container mx-auto px-6 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <div class="text-neutral-400 text-sm">
          © {currentYear} {companyName}. All rights reserved.
        </div>
        <div class="flex flex-wrap items-center space-x-6 text-sm">
          <a href="/privacy" class="text-neutral-400 hover:text-white transition-colors duration-200">Privacy Policy</a>
          <a href="/data-use-policy" class="text-neutral-400 hover:text-white transition-colors duration-200">Data Use Policy</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  // Newsletter subscription handler
  document.addEventListener('DOMContentLoaded', function() {
    const newsletterForm = document.getElementById('newsletter-form');

    if (newsletterForm) {
      newsletterForm.addEventListener('submit', async function(e) {
        e.preventDefault();

        const emailInput = document.getElementById('newsletter-email');
        const submitBtn = document.getElementById('newsletter-submit');
        const submitText = document.getElementById('newsletter-text');
        const messageDiv = document.getElementById('newsletter-message');

        const email = emailInput.value.trim();

        if (!email) {
          showMessage('Please enter your email address', 'error');
          return;
        }

        // Show loading state
        submitBtn.disabled = true;
        submitText.textContent = 'Subscribing...';
        messageDiv.classList.add('hidden');

        try {
          const response = await fetch('/api/subscribe', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              email: email,
              source: 'footer'
            })
          });

          const result = await response.json();

          if (response.ok) {
            showMessage('Thank you! Please check your email to confirm your subscription.', 'success');
            emailInput.value = '';
          } else {
            if (response.status === 409) {
              showMessage('This email is already subscribed to our newsletter.', 'info');
            } else {
              showMessage(result.error || 'Failed to subscribe. Please try again.', 'error');
            }
          }
        } catch (error) {
          console.error('Newsletter subscription error:', error);
          showMessage('Network error. Please check your connection and try again.', 'error');
        } finally {
          // Reset button state
          submitBtn.disabled = false;
          submitText.textContent = 'Subscribe';
        }

        function showMessage(text, type) {
          messageDiv.textContent = text;
          messageDiv.classList.remove('hidden', 'text-green-400', 'text-red-400', 'text-blue-400');

          if (type === 'success') {
            messageDiv.classList.add('text-green-400');
          } else if (type === 'error') {
            messageDiv.classList.add('text-red-400');
          } else if (type === 'info') {
            messageDiv.classList.add('text-blue-400');
          }

          messageDiv.classList.remove('hidden');
        }
      });
    }
  });
</script>

<style>
  footer a:hover {
    text-decoration: none;
  }

  footer input:focus {
    outline: none;
  }
</style>

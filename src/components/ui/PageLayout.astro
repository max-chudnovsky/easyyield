---
// src/components/ui/PageLayout.astro - Reusable page layout with consistent header spacing
import Header from '../Header.astro';
import Footer from './Footer.astro';
import { footerConfig } from '../../data/footer';

export interface Props {
  title?: string;
  description?: string;
  className?: string;
  mainClass?: string;
  showFooter?: boolean;
  /** Explicit canonical URL. Defaults to the current page URL (origin + pathname, no query string). */
  canonical?: string;
  /** Set to true to add noindex,nofollow (admin/auth/utility pages). */
  noindex?: boolean;
}

const {
  title = "Easy Yield",
  description = "Canadian personal finance made easy and fun — a comics and vlog series with Mike.",
  className = "",
  mainClass = "min-h-screen pt-24",
  showFooter = true,
  canonical,
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical ?? `https://easyyield.ca${new URL(Astro.request.url).pathname.replace(/\/$/, '') || '/'}`;

---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/api/images/site/easyyield-logo.png" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <!-- Preload and static Tailwind CSS (built at build-time) -->
  <link rel="preload" href="/tailwind.css?v=20260628e" as="style">
  <link rel="stylesheet" href="/tailwind.css?v=20260628e">
  <!-- Minimal critical CSS to avoid FOUC until tailwind.css loads -->
  <style>
    html,body{font-family:Inter,system-ui,-apple-system}
  </style>
  <script> window.FontAwesomeConfig = { autoReplaceSvg: 'nest'};</script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro:ital,wght@0,200;0,300;0,400;0,600;0,700;0,900;1,200;1,300;1,400;1,600;1,700;1,900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&amp;display=swap" />
  <link rel="stylesheet" href="/styles/brand.css?v=20260629c">
  <script is:inline src="/js/analytics.js" defer></script>
</head>

<body class={className}>
  <Header />

  <main class={mainClass}>
    <slot />
  </main>

  {showFooter && (
    <Footer
      companyName={footerConfig.companyName}
      showSocialLinks={footerConfig.showSocialLinks}
      showQuickLinks={footerConfig.showQuickLinks}
      showNewsletter={footerConfig.showNewsletter}
    />
  )}
</body>